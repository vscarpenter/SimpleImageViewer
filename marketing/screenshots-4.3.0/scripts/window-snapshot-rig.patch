+#if DEBUG
+/// Renders the main window into a PNG at 2x scale so Retina-quality marketing
+/// screenshots can be produced even when the attached display is 1x. Writing
+/// goes to the sandbox container's tmp directory (the only place a Debug build
+/// can write without a user grant). Never compiled into Release builds.
+enum DebugWindowSnapshot {
+    private static var sequence = 0
+
+    /// 1440×900 pt is 16:10 — snapshotted at 2x it yields 2880×1800 px,
+    /// the largest Mac App Store screenshot size.
+    @MainActor
+    static func setStandardFrame() {
+        guard let window = NSApp.mainWindow ?? NSApp.windows.first(where: { $0.isVisible }) else { return }
+        let size = NSSize(width: 1440, height: 900)
+        let vis = (window.screen ?? NSScreen.main)?.visibleFrame
+            ?? NSRect(origin: .zero, size: size)
+        let origin = NSPoint(x: vis.midX - size.width / 2, y: vis.midY - size.height / 2)
+        window.setFrame(NSRect(origin: origin, size: size), display: true, animate: false)
+    }
+
+    @MainActor
+    static func save() {
+        guard let window = NSApp.mainWindow ?? NSApp.windows.first(where: { $0.isVisible }),
+              // contentView.superview is the window's frame view: it includes
+              // the title-bar region and traffic lights, which a marketing
+              // screenshot needs; contentView alone would omit them.
+              let frameView = window.contentView?.superview,
+              let layer = frameView.layer else {
+            NSLog("DebugWindowSnapshot: no visible layer-backed window to capture")
+            return
+        }
+        // SwiftUI content on macOS 26 is composited by the window server
+        // (Metal-backed), so cacheDisplay/CALayer.render come back blank.
+        // Capturing our OWN window through the window server sees the real
+        // composited pixels and needs no Screen Recording permission.
+        // CGWindowListCreateImage is unavailable to Swift in the macOS 26 SDK
+        // (Apple points to ScreenCaptureKit, which TCC-prompts even for our
+        // own window), but the C symbol is still exported for binary
+        // compatibility — call it via dlsym. Debug-only code.
+        _ = layer // layer-backing confirmed above; capture goes via window id
+        window.displayIfNeeded()
+        typealias CreateImageFn = @convention(c) (CGRect, UInt32, UInt32, UInt32) -> Unmanaged<CGImage>?
+        guard let sym = dlsym(dlopen(nil, RTLD_NOW), "CGWindowListCreateImage") else {
+            NSLog("DebugWindowSnapshot: CGWindowListCreateImage symbol missing")
+            return
+        }
+        let createImage = unsafeBitCast(sym, to: CreateImageFn.self)
+        let windowID = UInt32(window.windowNumber)
+        let optionIncludingWindow: UInt32 = 1 << 3   // kCGWindowListOptionIncludingWindow
+        let boundsIgnoreFraming: UInt32 = 1 << 0     // kCGWindowImageBoundsIgnoreFraming
+        let bestResolution: UInt32 = 1 << 3          // kCGWindowImageBestResolution
+        guard let cgImage = createImage(
+            .null,
+            optionIncludingWindow,
+            windowID,
+            boundsIgnoreFraming | bestResolution
+        )?.takeRetainedValue() else {
+            NSLog("DebugWindowSnapshot: CGWindowListCreateImage returned nil")
+            return
+        }
+        guard let png = NSBitmapImageRep(cgImage: cgImage)
+            .representation(using: .png, properties: [:]) else {
+            NSLog("DebugWindowSnapshot: PNG encoding failed")
+            return
+        }
+        let dir = URL(fileURLWithPath: NSTemporaryDirectory())
+            .appendingPathComponent("snapshots", isDirectory: true)
+        do {
+            try FileManager.default.createDirectory(at: dir, withIntermediateDirectories: true)
+            sequence += 1
+            let url = dir.appendingPathComponent(String(format: "snap-%03d.png", sequence))
+            try png.write(to: url)
+            NSLog("DebugWindowSnapshot: wrote \(url.path)")
+        } catch {
+            NSLog("DebugWindowSnapshot: write failed - \(error)")
+        }
+    }
+}
+#endif
